{
  "name": "com.hockeypickup.app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 5174",
    "build": "yarn build-version && tsc -b && vite build",
    "lint": "eslint . --config eslint.config.cjs",
    "format": "prettier --write \"**/*.{ts,tsx}\" --config ./.prettierrc",
    "preview": "vite preview",
    "refresh-api:local": "curl --insecure --output HockeyPickup.Api.swagger.json https://localhost:7042/swagger/v1/swagger.json && npx swagger-typescript-api generate --no-client --path ./HockeyPickup.Api.swagger.json --output ./src --name HockeyPickup.Api.ts",
    "refresh-api:prod": "npx swagger-typescript-api generate --no-client --path https://api.HockeyPickup.org/swagger/v1/swagger.json --output ./src --name HockeyPickup.Api.ts",
    "build-version": "bash ./scripts/build-version.sh",
    "update-packages": "ncu -u",
    "check-deps": "npx depcheck"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/carousel": "^9.3.2",
    "@mantine/core": "^9.3.2",
    "@mantine/dates": "^9.3.2",
    "@mantine/dropzone": "^9.3.2",
    "@mantine/form": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@mantine/modals": "^9.3.2",
    "@mantine/notifications": "^9.3.2",
    "@microlink/react-json-view": "^1.31.20",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.18.0",
    "dayjs": "^1.11.21",
    "graphql": "^16.14.2",
    "graphql-ws": "^6.0.8",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.18.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "depcheck": "^1.4.7",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "npm-check-updates": "^22.2.7",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "swagger-typescript-api": "^13.12.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  },
  "packageManager": "yarn@1.22.22"
}
